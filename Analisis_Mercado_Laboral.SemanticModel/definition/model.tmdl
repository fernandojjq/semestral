model Model
	culture: es-MX
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-MX
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Dim_Clusters","Dim_Empresas","Dim_Fecha","Dim_Habilidades","Dim_Portales","Dim_Puestos","Fact_Vacante_Habilidad","Fact_Vacantes"]

annotation PBI_ProTooling = ["DevMode"]

ref table Dim_Clusters
ref table Dim_Empresas
ref table Dim_Fecha
ref table Dim_Habilidades
ref table Dim_Portales
ref table Dim_Puestos
ref table Fact_Vacante_Habilidad
ref table Fact_Vacantes
ref table Medidas

ref cultureInfo es-MX

